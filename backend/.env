# Xeno CRM Backend — SQLite (no installation needed)
DATABASE_URL="file:./xeno.db"

# Server
PORT=3001
NODE_ENV=development

# Channel Service URL
CHANNEL_SERVICE_URL=http://localhost:4001

# Backend URL (for webhook callbacks)
BACKEND_URL=http://localhost:3001

# Gemini API Key (optional — AI works without it using keyword fallback)
GEMINI_API_KEY=

# CORS
CORS_ORIGIN=http://localhost:5173
